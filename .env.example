# ===========================================
# Magellan Project - Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
#
# This is the single source of truth for all configuration.
# trading-standalone and other services read from this file.

# ========== LLM API Keys ==========
# At least one is required based on DEFAULT_LLM_PROVIDER

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL_NAME=gemini-3-flash-preview

# Moonshot Kimi
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL_NAME=moonshot-v1-128k

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-chat

# Default LLM provider: gemini, kimi, deepseek
DEFAULT_LLM_PROVIDER=deepseek

# ========== Web Search APIs ==========
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# ========== OKX Exchange ==========
# Get from: https://www.okx.com/account/my-api
# IMPORTANT: Use Demo Trading API keys for testing!

# Hosted-testing default:
# - Do NOT put your OKX keys into server .env.
# - Users should configure OKX demo credentials from the Trading Settings UI.
#
# If you really need env-based OKX credentials (admin-only), you must opt-in:
# OKX_ALLOW_ENV_CREDENTIALS=true
#
# OKX_API_KEY=your_okx_api_key_here
# OKX_SECRET_KEY=your_okx_secret_key_here
# OKX_PASSPHRASE=your_okx_passphrase_here
#
# OKX_DEMO_MODE=true
# USE_OKX_TRADING=false
OKX_ALLOW_ENV_CREDENTIALS=false

# ========== Trading Parameters ==========
TRADING_SYMBOL=BTC-USDT-SWAP

# ========== Risk Control ==========
MAX_LEVERAGE=20
MAX_POSITION_PERCENT=100
MIN_POSITION_PERCENT=40
DEFAULT_POSITION_PERCENT=60
MIN_CONFIDENCE=55
DEFAULT_TP_PERCENT=8.0
DEFAULT_SL_PERCENT=3.0

# ========== Scheduler ==========
SCHEDULER_INTERVAL_HOURS=2
COOLDOWN_HOURS=24
MAX_CONSECUTIVE_LOSSES=3

# ========== Agent Weights (Advanced) ==========
AGENT_WEIGHT_ENABLED=true
AGENT_WEIGHT_BASE=1.0
AGENT_WEIGHT_ACCURACY_FACTOR=0.5
AGENT_WEIGHT_RECENCY_FACTOR=0.3
AGENT_WEIGHT_MIN=0.5
AGENT_WEIGHT_MAX=2.0
AGENT_WEIGHT_MIN_TRADES=5

# ========== Timeouts (seconds) ==========
LLM_REQUEST_TIMEOUT=120
AGENT_ACTION_TIMEOUT=300
MEETING_TURN_TIMEOUT=180
MEETING_TOTAL_TIMEOUT=1200
HTTP_CLIENT_TIMEOUT=30

# ========== Infrastructure ==========
REDIS_URL=redis://redis:6379
REDIS_MAX_MEMORY=256mb
LOG_LEVEL=INFO

# ========== PoC Safety Defaults ==========
# Fail-fast if Redis is not available (prevents silent data loss via in-memory fallback).
REPORT_ORCH_REQUIRE_REDIS=true
# Disable in-memory report storage fallback.
REPORT_STORAGE_ALLOW_MEMORY_FALLBACK=false
# Disable test-only endpoints (/api/trading/mock/*) by default.
ENABLE_TEST_ENDPOINTS=false
# Tight CORS; use "*" only if you really need cross-origin access.
CORS_ALLOW_ORIGINS=http://localhost:5174,http://localhost:8081
# Hard caps for uploads (bytes/MB) to avoid memory and disk abuse.
FILE_SERVICE_MAX_UPLOAD_BYTES=52428800
FILE_SERVICE_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.csv,.txt
REPORT_ORCH_UPLOAD_MAX_MB=50
KNOWLEDGE_UPLOAD_MAX_MB=20
# LLM gateway abuse controls.
LLM_RATE_LIMIT_PER_MINUTE=60
LLM_MAX_HISTORY_MESSAGES=120
LLM_MAX_MESSAGE_CHARS=8000
LLM_MAX_TOTAL_CHARS=60000
LLM_UPLOAD_MAX_BYTES=20971520
# Keep provider/model details private unless explicitly needed by admins.
LLM_EXPOSE_PROVIDER_INFO=false
# External data mock is disabled by default for truthful PoC behavior.
EXTERNAL_DATA_ALLOW_MOCK=false
# Gemini embeddings (Knowledge Base / RAG)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_EMBEDDING_TASK_DOCUMENT=RETRIEVAL_DOCUMENT
GEMINI_EMBEDDING_TASK_QUERY=RETRIEVAL_QUERY
# If existing Qdrant collection dimension differs, recreate automatically.
QDRANT_AUTO_RECREATE_COLLECTION=true
# Internal knowledge compatibility proxy (single KB implementation in report_orchestrator)
INTERNAL_KB_UPSTREAM_URL=http://report_orchestrator:8000
INTERNAL_KB_UPSTREAM_TIMEOUT=30
# Report orchestrator agents call this endpoint for knowledge search.
INTERNAL_KNOWLEDGE_URL=http://internal_knowledge_service:8009

# ========== Email Notifications (Optional) ==========
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com
