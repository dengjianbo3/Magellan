# Magellan Frontend Environment Variables
# Copy this file to .env.local for local development

# IMPORTANT:
# VITE_API_BASE / VITE_AUTH_BASE should be HOST root (without /api or /api/auth).
# Code will append route prefixes internally.

# API/Auth host root
VITE_API_BASE=http://localhost
VITE_AUTH_BASE=http://localhost

# WebSocket Base URL
VITE_WS_BASE=ws://localhost

# LLM gateway base (this one should include /api/llm)
VITE_LLM_BASE=http://localhost/api/llm

# Production settings (uncomment and modify for production)
# VITE_API_BASE=https://your.domain.com
# VITE_AUTH_BASE=https://your.domain.com
# VITE_WS_BASE=wss://your.domain.com
# VITE_LLM_BASE=https://your.domain.com/api/llm
